# OpenAI — genere les prompts (GPT-4o) et les images (gpt-image-1)
OPENAI_API_KEY=sk-...

# Pinterest OAuth — credentials de ton app developer (developers.pinterest.com)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Session — secret pour chiffrer les cookies (min 32 caracteres)
# Genere avec: openssl rand -hex 32
SESSION_SECRET=

# Upstash Redis — stockage des tokens et posts programmes
# Cree un store gratuit sur https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron — secret pour authentifier les appels cron
# Genere avec: openssl rand -hex 32
CRON_SECRET=

# (Optionnel) URL de base pour les redirects OAuth
# En local: http://localhost:3002, en prod: https://ton-domaine.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3002

# (Optionnel) Webhook pour notifications email/Slack
NOTIFICATION_WEBHOOK_URL=

# --- LEGACY (backward compatible, utilisez OAuth a la place) ---
# PINTEREST_ACCESS_TOKEN=pina_...
# PINTEREST_BOARD_ID=
